# SMS Gateway Configuration
# Copy this file to .env and fill in your actual credentials

# Choose SMS provider: 'twilio', 'fast2sms', or 'demo'
SMS_PROVIDER=demo

# Twilio Configuration (Paid - More reliable, works globally)
# Get credentials from https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Fast2SMS Configuration (Free for India - Limited but no cost)
# Get API key from https://www.fast2sms.com/
# Note: Use 'otp' route for free SMS, 'promotional' for bulk
FAST2SMS_API_KEY=your_fast2sms_api_key_here
FAST2SMS_ROUTE=otp

# Database Configuration (optional)
DATABASE=security_system.db

# Flask Configuration (optional)
FLASK_SECRET_KEY=your_secret_key_here
FLASK_ENV=development
